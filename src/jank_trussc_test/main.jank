(ns jank-trussc-test.main)

(cpp/raw "

#ifdef _WIN32
#include \"safe_snprintf.h\" // WORKAROUND
#define snprintf _safe_snprintf
#include \"safe_snprintf.cpp\" // WORKAROUND
#endif // _WIN32

#include <cstdio>
#include <iostream>
#include <sstream>
#include <iomanip>

#include <TrussC.h>
          
#include \"tcGlobal.cpp\" // WORKAROUND
#include \"tcPlatform.cpp\" // WORKAROUND
          
using namespace std;
using namespace tc;
          
jank::runtime::oref<jank::runtime::object> init_callback;
jank::runtime::oref<jank::runtime::object> update_callback;
jank::runtime::oref<jank::runtime::object> draw_callback;
          
void set_init_callback(jank::runtime::oref<jank::runtime::object> obj){
    init_callback = obj;
}

void set_update_callback(jank::runtime::oref<jank::runtime::object> obj){
    update_callback = obj;
}

void set_draw_callback(jank::runtime::oref<jank::runtime::object> obj){
    draw_callback = obj;
}

void call_init_callback(){
  dynamic_call(init_callback);
}
          
void call_update_callback(){
  dynamic_call(update_callback);
}

void call_draw_callback(){
  dynamic_call(draw_callback);
}

class tcApp : public App {
public:
    void setup() override;
    void update() override;
    void draw() override;

    void keyPressed(int key) override;
    void keyReleased(int key) override;

    void mousePressed(Vec2 pos, int button) override;
    void mouseReleased(Vec2 pos, int button) override;
    void mouseMoved(Vec2 pos) override;
    void mouseDragged(Vec2 pos, int button) override;
    void mouseScrolled(Vec2 delta) override;

    void windowResized(int width, int height) override;
    void filesDropped(const vector<string>& files) override;
    void exit() override;
};

void tcApp::setup() {
    call_init_callback();
}

std::string fps2string(float fps){
    std::ostringstream oss;
    oss << \"FPS: \" << std::fixed << std::setprecision(2) << fps;
    std::string s = oss.str();
    return s;
}

void tcApp::update() {
    call_update_callback();

    // float r = getFrameRate();
    // setWindowTitle(fps2string(r));
}

void tcApp::draw() {
    trussc_clear(0.12f, 0, 0, 1);

    // Rotating box
    pushMatrix();
    pushStyle();

    noFill();
    translate(getWindowWidth() / 2, getWindowHeight() / 2);
    rotate(getElapsedTimef() *0.1f, getElapsedTimef() *0.15f, 0);
    drawBox(200.0f);

    popStyle();
    popMatrix();

    call_draw_callback();
}

void tcApp::keyPressed(int key) {}
void tcApp::keyReleased(int key) {}

void tcApp::mousePressed(Vec2 pos, int button) {}
void tcApp::mouseReleased(Vec2 pos, int button) {}
void tcApp::mouseMoved(Vec2 pos) {}
void tcApp::mouseDragged(Vec2 pos, int button) {}
void tcApp::mouseScrolled(Vec2 delta) {}

void tcApp::windowResized(int width, int height) {}
void tcApp::filesDropped(const vector<string>& files) {}
void tcApp::exit() {}

void run() {
    tc::WindowSettings settings;
    settings.setSize(960, 600);

    tc::runApp<tcApp>(settings);
}

")

(def is_first_draw (atom true))
(def is_first_update (atom true))

(defn init []
  (println "init from jank!"))

(defn update []
  (if @is_first_update
    (do
      (println "first update from jank!")
      (reset! is_first_update false)))
  (let [fps (cpp/tc.getFrameRate)]
    (cpp/tc.setWindowTitle (cpp/fps2string fps))))

(defn draw []
  (if @is_first_draw
    (do
      (println "first draw from jank!")
      (reset! is_first_draw false)))
  (do
    (cpp/trussc.noFill)
    (cpp/trussc.drawCircle 150.0 150.0 70.0)
    ))

(defn -main [& args]
  (cpp/set_init_callback init)
  (cpp/set_update_callback update)
  (cpp/set_draw_callback draw)
  (cpp/run))
